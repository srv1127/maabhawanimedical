{
  "version": 1,
  "sdk_version": "0.22.2",
  "path": "/mcp",
  "auth": {
    "type": "oauth",
    "issuer": "https://miphwtwamyvwvfgfhsnr.supabase.co/auth/v1",
    "accepted_audiences": [
      "authenticated"
    ]
  },
  "mcp": {
    "server": {
      "name": "maa-bhawani-medical",
      "version": "0.1.0",
      "title": "Maa Bhawani Medical"
    },
    "tools": [
      {
        "name": "list_medicines",
        "title": "List / search medicines",
        "description": "Search the pharmacy inventory. Optional query matches name, generic name, or barcode. Returns up to `limit` medicines with stock, MRP, and sell price.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "query": {
              "type": "string",
              "description": "Optional search text matched against name/generic/barcode."
            },
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100,
              "description": "Max results (default 25)."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_low_stock",
        "title": "List low-stock medicines",
        "description": "Return medicines whose current quantity is at or below the given threshold (default 10).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "threshold": {
              "type": "integer",
              "minimum": 0,
              "maximum": 1000,
              "description": "Stock threshold. Default 10."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "list_expiring_medicines",
        "title": "List medicines expiring soon",
        "description": "Return medicines whose expiry date falls within the next `days` days (default 90).",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "days": {
              "type": "integer",
              "minimum": 1,
              "maximum": 365,
              "description": "Days ahead to look. Default 90."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "recent_sales",
        "title": "Recent sales",
        "description": "Return the most recent sales (invoice number, totals, timestamp). Default 10, max 100.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "limit": {
              "type": "integer",
              "minimum": 1,
              "maximum": 100
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      },
      {
        "name": "sales_summary",
        "title": "Sales summary for a date range",
        "description": "Aggregate sales between two ISO dates (YYYY-MM-DD, inclusive). Returns count, gross, tax, and net total. Omit dates for today.",
        "annotations": {
          "readOnlyHint": true,
          "idempotentHint": true,
          "openWorldHint": false
        },
        "inputSchema": {
          "type": "object",
          "properties": {
            "from": {
              "type": "string",
              "description": "Start date YYYY-MM-DD."
            },
            "to": {
              "type": "string",
              "description": "End date YYYY-MM-DD."
            }
          },
          "additionalProperties": false,
          "$schema": "http://json-schema.org/draft-07/schema#"
        },
        "outputSchema": null
      }
    ]
  }
}
